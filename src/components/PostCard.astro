---
interface Props {
	title: string;
	description: string;
    pubDate: string;
	slug: string;
	tags?: string[];
}

const { title, description, pubDate, slug, tags = [] } = Astro.props;
---
<li class="border border-zinc-200 rounded-lg p-5 bg-zinc-50 hover:border-zinc-400 hover:shadow-sm transition-all flex flex-col">
	<h2 class="text-xl font-normal mb-1">
		<a href={`/${slug}`} class="text-zinc-600 underline underline-offset-2 decoration-zinc-300 hover:text-zinc-900 hover:decoration-zinc-600 transition-colors">{title}</a>
	</h2>
	<p class="text-zinc-400 text-xs mb-2">{pubDate}</p>
	<p class="text-zinc-500 text-sm flex-1">{description}</p>
	{tags.length > 0 && (
		<div class="flex flex-wrap gap-2 mt-3">
			{tags.map(tag => (
				<a
					href={`/tags/${tag.toLowerCase()}`}
					class="text-xs bg-zinc-200 text-zinc-600 px-2 py-1 rounded hover:bg-zinc-300 transition-colors"
				>
					#{tag}
				</a>
			))}
		</div>
	)}
</li>
