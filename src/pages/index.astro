---
import HomeLayout from '../layouts/HomeLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../config';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const { postsPerPage } = siteConfig.pagination;
const totalPages = Math.ceil(allPosts.length / postsPerPage);
const posts = allPosts.slice(0, postsPerPage);
---
<HomeLayout>
	{posts.map(post => (
		<PostCard
			title={post.data.title}
			description={post.data.description}
			pubDate={post.data.pubDate.toISOString().slice(0, 10)}
			slug={post.data.slug}
			tags={post.data.tags}
		/>
	))}

	{totalPages > 1 && (
		<li class="col-span-2 flex justify-center items-center gap-4 mt-6 list-none">
			<a href="/p/2" class="text-zinc-500 hover:text-zinc-900 transition-colors text-lg leading-none">❯</a>
		</li>
	)}
</HomeLayout>
