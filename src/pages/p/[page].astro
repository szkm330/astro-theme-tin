---
import HomeLayout from '../../layouts/HomeLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { siteConfig } from '../../config';

export async function getStaticPaths() {
	const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
	const { postsPerPage } = siteConfig.pagination;
	const totalPages = Math.ceil(allPosts.length / postsPerPage);

	return Array.from({ length: totalPages - 1 }, (_, i) => {
		const pageNum = i + 2;
		return {
			params: { page: String(pageNum) },
			props: {
				currentPage: pageNum,
				totalPages,
				posts: allPosts.slice((pageNum - 1) * postsPerPage, pageNum * postsPerPage),
			},
		};
	});
}

interface Props {
	currentPage: number;
	totalPages: number;
	posts: CollectionEntry<'blog'>[];
}

const { currentPage, totalPages, posts } = Astro.props;
const prevUrl = currentPage === 2 ? '/' : `/p/${currentPage - 1}`;
const nextUrl = `/p/${currentPage + 1}`;
---
<HomeLayout>
	{posts.map((post) => (
		<PostCard
			title={post.data.title}
			description={post.data.description}
			pubDate={post.data.pubDate.toISOString().slice(0, 10)}
			slug={post.data.slug}
			tags={post.data.tags}
		/>
	))}

	<li class="col-span-2 flex justify-center items-center gap-4 mt-6 list-none">
		<a href={prevUrl} class="text-zinc-500 hover:text-zinc-900 transition-colors text-lg leading-none">❮</a>
		{currentPage < totalPages ? (
			<a href={nextUrl} class="text-zinc-500 hover:text-zinc-900 transition-colors text-lg leading-none">❯</a>
		) : (
			<span class="text-zinc-300 text-lg leading-none cursor-not-allowed">❯</span>
		)}
	</li>
</HomeLayout>
