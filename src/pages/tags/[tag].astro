---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // 集合所有标签
  const tags = new Set<string>();
  posts.forEach((post) => {
    if (!post.data.tags || !Array.isArray(post.data.tags)) return;
    post.data.tags.forEach((tag) => {
      tags.add(tag.toLowerCase());
    });
  });

  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const posts = await getCollection('blog');
const lowercaseTag = tag.toLowerCase();

// 过滤并排序文章
const filteredPosts = posts
  .filter((post) =>
    post.data.tags?.map((t) => t.toLowerCase()).includes(lowercaseTag)
  )
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  );
---

<BaseLayout title={`Tag: ${tag}`}>
  <main class="py-12">
    <a href="/tags" class="text-zinc-500 hover:text-zinc-900 text-sm mb-6 inline-block transition-colors">← Back to Tags</a>

    <h1 class="text-3xl font-normal mb-2">Tag: {tag}</h1>
    <p class="text-zinc-500 mb-8">{filteredPosts.length} posts</p>

    {filteredPosts.length > 0 ? (
      <ul class="space-y-2">
        {filteredPosts.map((post) => (
          <li class="flex items-baseline gap-4">
            <span class="text-zinc-400 text-sm tabular-nums shrink-0">{post.data.pubDate.toISOString().slice(0, 10)}</span>
            <a href={`/${post.data.slug}`} class="hover:text-zinc-900 transition-colors">{post.data.title}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-zinc-500">No posts yet</p>
    )}
  </main>
</BaseLayout>
