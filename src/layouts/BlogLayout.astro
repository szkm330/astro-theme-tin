---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import 'katex/dist/katex.min.css';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, tags = [] } = Astro.props;
---
<BaseLayout title={title}>
	<main class="py-12">
		<article>
			<div class="mb-12 pb-8 border-b border-zinc-200">
				<div class="text-sm text-zinc-400 mb-4">
					{pubDate.toISOString().slice(0, 10)}
				</div>
				<h1 class="text-[2rem] font-normal mb-4 text-zinc-900">{title}</h1>
				<p class="text-[1.05rem] text-zinc-500 leading-relaxed">{description}</p>
				{tags && tags.length > 0 && (
					<div class="flex flex-wrap gap-2 mt-4">
						{tags.map(tag => (
							<a
								href={`/tags/${tag.toLowerCase()}`}
								class="text-sm bg-zinc-200 text-zinc-600 px-3 py-1 rounded hover:bg-zinc-300 transition-colors"
							>
								#{tag}
							</a>
						))}
					</div>
				)}
			</div>
			<div class="prose prose-zinc max-w-none overflow-x-auto
				prose-headings:font-normal
				prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
				prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
				prose-p:text-zinc-600 prose-p:my-4
				prose-a:text-zinc-600 prose-a:underline hover:prose-a:text-zinc-900
				prose-img:my-8
				prose-pre:my-6
				prose-code:before:content-none prose-code:after:content-none
				prose-blockquote:border-l-2 prose-blockquote:border-zinc-200 prose-blockquote:pl-6 prose-blockquote:text-zinc-500 prose-blockquote:italic
				prose-ul:my-4 prose-ol:my-4
				prose-li:my-2
				prose-hr:border-zinc-200 prose-hr:my-8
				prose-table:text-sm prose-table:w-full
				prose-thead:border-b prose-thead:border-zinc-200
				prose-th:px-4 prose-th:py-2 prose-th:text-left prose-th:font-medium prose-th:text-zinc-700
				prose-td:px-4 prose-td:py-2 prose-td:border-b prose-td:border-zinc-100
			">
				<slot />
			</div>
		</article>
	</main>

	<!-- TOC floating button -->
	<div class="fixed bottom-8 left-8 flex flex-col items-start gap-2">
		<div
			id="toc-panel"
			class="hidden mb-1 bg-white border border-zinc-200 rounded shadow-lg w-52 max-h-64 overflow-y-auto toc-panel"
		>
			<ol id="toc-list" class="py-2 px-3 space-y-1 text-sm"></ol>
		</div>
		<button
			id="toc-btn"
			aria-label="目录"
			class="p-2 bg-zinc-800 text-white rounded-full transition-colors duration-200 hover:bg-zinc-600"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="3" y1="6" x2="21" y2="6"></line>
				<line x1="3" y1="12" x2="15" y2="12"></line>
				<line x1="3" y1="18" x2="18" y2="18"></line>
			</svg>
		</button>
	</div>

</BaseLayout>

<script>
	// Copy button
	document.querySelectorAll<HTMLElement>('article pre').forEach(pre => {
		const btn = document.createElement('button');
		btn.className = 'copy-btn';
		btn.textContent = 'copy';
		btn.onclick = async () => {
			await navigator.clipboard.writeText(pre.querySelector('code')?.innerText ?? '');
			btn.textContent = '✓';
			setTimeout(() => btn.textContent = 'copy', 1500);
		};
		pre.append(btn);
	});

	// TOC
	const tocBtn = document.getElementById('toc-btn')!;
	const tocPanel = document.getElementById('toc-panel')!;
	const tocList = document.getElementById('toc-list')!;
	const headings = document.querySelectorAll<HTMLElement>('article h2, article h3');

	if (headings.length === 0) {
		tocBtn.style.display = 'none';
	} else {
		headings.forEach((h, i) => {
			if (!h.id) h.id = `heading-${i}`;
			const li = document.createElement('li');
			const a = document.createElement('a');
			a.href = `#${h.id}`;
			a.textContent = h.textContent;
			a.className = h.tagName === 'H3'
				? 'block py-0.5 pl-3 text-zinc-500 hover:text-zinc-900 transition-colors'
				: 'block py-0.5 text-zinc-700 hover:text-zinc-900 transition-colors';
			a.addEventListener('click', () => tocPanel.classList.add('hidden'));
			li.appendChild(a);
			tocList.appendChild(li);
		});

		tocBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			tocPanel.classList.toggle('hidden');
		});

		document.addEventListener('click', (e) => {
			if (!tocPanel.contains(e.target as Node)) {
				tocPanel.classList.add('hidden');
			}
		});
	}
</script>

<style is:global>
  .prose mark {
    background-color: #fef08a;
    color: inherit;
    padding: 0.1em 0.2em;
    border-radius: 2px;
  }

  .toc-panel::-webkit-scrollbar {
    width: 4px;
  }
  .toc-panel::-webkit-scrollbar-track {
    background: transparent;
  }
  .toc-panel::-webkit-scrollbar-thumb {
    background-color: #d4d4d8;
    border-radius: 9999px;
  }
  .toc-panel::-webkit-scrollbar-thumb:hover {
    background-color: #a1a1aa;
  }

  .prose pre {
    position: relative;
  }

  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.6rem;
    font-size: 1.0rem;
    color: #71717a;
    background: transparent;
    border: none;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s, color 0.15s;
  }

  .prose pre:hover .copy-btn {
    opacity: 1;
  }

  .copy-btn:hover {
    color: #e4e4e7;
  }

  .prose :not(pre) > code {
    color: #166534;
    background-color: #f4f4f5;
    border: 1px solid #d4d4d8;
    padding: 0.15em 0.35em;
    border-radius: 4px;
    font-size: 0.875em;
  }
</style>
